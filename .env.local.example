# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32  (or any random string)
NEXTAUTH_SECRET=your-super-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ─── Admin Credentials ────────────────────────────────────────────────────────
# These are the credentials you use to log in to /admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-password-here

# ─── No database needed! ──────────────────────────────────────────────────────
# All portfolio data is stored in /data/*.json files.
# Run npm run dev locally, use the admin panel to add/edit content,
# then git commit + push to publish changes to Vercel.
